# Copy to .env when you want the checker to validate a concrete runtime.
# Do not commit real secrets. This template mirrors every RAG-Anything env
# capability known to configs/rag-tool-check.toml.

### Server
HOST=0.0.0.0
PORT=9621
WEBUI_TITLE='My Graph KB'
WEBUI_DESCRIPTION="Simple and Fast Graph Based RAG System"
OLLAMA_EMULATING_MODEL_TAG=latest
# WORKERS=2
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

### Offline / directories
# TIKTOKEN_CACHE_DIR=./tiktoken_cache
# INPUT_DIR=./inputs
OUTPUT_DIR=./output
WORKING_DIR=./rag_storage

### Auth / SSL
# AUTH_ACCOUNTS='admin:admin123,user1:pass456'
# TOKEN_SECRET=replace_me
# TOKEN_EXPIRE_HOURS=48
# GUEST_TOKEN_EXPIRE_HOURS=24
# JWT_ALGORITHM=HS256
# LIGHTRAG_API_KEY=replace_me
# WHITELIST_PATHS=/health,/api/*
# SSL=false
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

### Parser
PARSER=mineru
PARSE_METHOD=auto
# MINERU_PARSE_METHOD=auto
DISPLAY_CONTENT_STATS=true
USE_FULL_PATH=false

### Multimodal processors
ENABLE_IMAGE_PROCESSING=true
ENABLE_TABLE_PROCESSING=true
ENABLE_EQUATION_PROCESSING=true

### Batch
MAX_CONCURRENT_FILES=1
SUPPORTED_FILE_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.bmp,.tiff,.tif,.gif,.webp,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.md
RECURSIVE_FOLDER_PROCESSING=true
# MAX_PARALLEL_INSERT=2

### Context
CONTEXT_WINDOW=1
CONTEXT_MODE=page
MAX_CONTEXT_TOKENS=2000
INCLUDE_HEADERS=true
INCLUDE_CAPTIONS=true
CONTEXT_FILTER_CONTENT_TYPES=text
CONTENT_FORMAT=minerU

### Public media URLs
# RAGANYTHING_PUBLIC_ASSET_BASE_URL=https://my-bucket.s3.amazonaws.com/prefix
# RAGANYTHING_PUBLIC_ASSET_STRIP_PREFIX=/absolute/path/to/sync/root

### Logging
# LOG_LEVEL=INFO
# VERBOSE=false
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
# LOG_DIR=./logs

### Query / retrieval / chunking
# HISTORY_TURNS=3
# COSINE_THRESHOLD=0.2
# TOP_K=60
# MAX_GRAPH_NODES=1000
# MAX_TOKEN_TEXT_CHUNK=4000
# MAX_TOKEN_RELATION_DESC=4000
# MAX_TOKEN_ENTITY_DESC=4000
# MAX_TOKEN_SUMMARY=500
# FORCE_LLM_SUMMARY_ON_MERGE=6
SUMMARY_LANGUAGE=English
# CHUNK_SIZE=1200
# CHUNK_OVERLAP_SIZE=100
# RERANK_MODEL=
# RERANK_BINDING_HOST=
# RERANK_BINDING_API_KEY=replace_me

### LLM / VLM
ENABLE_LLM_CACHE=true
ENABLE_LLM_CACHE_FOR_EXTRACT=true
TIMEOUT=240
TEMPERATURE=0
MAX_ASYNC=4
MAX_TOKENS=32768
LLM_BINDING=ollama
LLM_MODEL=qwen2.5:1.5b
# VISION_MODEL requires a pulled Ollama vision-capable model and a matching
# vision_model_func integration.
# VISION_MODEL=qwen2.5vl:3b
LLM_BINDING_HOST=http://localhost:11434/v1
LLM_BINDING_API_KEY=ollama
# OPENAI_API_KEY=replace_me
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

### Embeddings
EMBEDDING_BINDING=ollama
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_BINDING_API_KEY=ollama
# EMBEDDING_BATCH_NUM=32
# EMBEDDING_FUNC_MAX_ASYNC=16
# MAX_EMBED_TOKENS=8192
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# AZURE_EMBEDDING_API_VERSION=2023-05-15

### Storage selection
# LIGHTRAG_KV_STORAGE=PGKVStorage
# LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
# LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
# LIGHTRAG_GRAPH_STORAGE=Neo4JStorage

### PostgreSQL
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=your_username
# POSTGRES_PASSWORD=replace_me
# POSTGRES_DATABASE=your_database
# POSTGRES_MAX_CONNECTIONS=12
# POSTGRES_WORKSPACE=default

### Neo4j
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=replace_me

### Apache AGE
# AGE_POSTGRES_DB=
# AGE_POSTGRES_USER=
# AGE_POSTGRES_PASSWORD=replace_me
# AGE_POSTGRES_HOST=
# AGE_POSTGRES_PORT=8529
# AGE_GRAPH_NAME=lightrag

### TiDB deprecated
# TIDB_HOST=localhost
# TIDB_PORT=4000
# TIDB_USER=your_username
# TIDB_PASSWORD=replace_me
# TIDB_DATABASE=your_database
# TIDB_WORKSPACE=default

### MongoDB
# MONGO_URI=mongodb://root:root@localhost:27017/
# MONGO_DATABASE=LightRAG
# MONGODB_GRAPH=false

### Milvus
# MILVUS_URI=http://localhost:19530
# MILVUS_DB_NAME=lightrag
# MILVUS_USER=root
# MILVUS_PASSWORD=replace_me
# MILVUS_TOKEN=replace_me

### Qdrant / Redis
# QDRANT_URL=http://localhost:16333
# QDRANT_API_KEY=replace_me
# REDIS_URI=redis://localhost:6379

### Ollama example-specific settings
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_LLM_MODEL=llama3.2
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_EMBEDDING_DIM=768

### MiniMax example-specific settings
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_API_KEY=replace_me
# MINIMAX_LLM_MODEL=MiniMax-M2.7
